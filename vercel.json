{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "composer install --no-dev --prefer-dist --optimize-autoloader",
    "functions": {
      "api/index.php": {
        "runtime": "vercel-php@0.9.0",
        "memory": 1024,
        "maxDuration": 30
      }
    },
    "rewrites": [
      {
        "source": "/assets/(.*)",
        "destination": "/assets/$1"
      },
      {
        "source": "/(.*)",
        "destination": "/api/index.php"
      }
    ]
  }